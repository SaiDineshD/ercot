# ERCOT Market Intelligence - Environment Variables
# Copy to .env and fill in your values

# EIA API (get your key at https://www.eia.gov/opendata/)
EIA_API_KEY=your_eia_api_key_here

# TimescaleDB
POSTGRES_USER=ercot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ercot_market
DB_HOST=timescaledb
DB_PORT=5432
DATABASE_URL=postgresql://ercot:change_me_in_production@timescaledb:5432/ercot_market

# Model paths (inside containers)
MODEL_DIR=/models

# HTTP /health inside each ingest + model-trainer (Compose healthchecks)
HEALTH_PORT=8080

# Ingest intervals (seconds)
LOAD_POLL_INTERVAL=300
WEATHER_POLL_INTERVAL=3600
PRICE_POLL_INTERVAL=900
OUTAGE_POLL_INTERVAL=300

# Optional: POST JSON alert payloads (Slack/custom webhook)
ALERT_WEBHOOK_URL=

# Comma-separated hub names for price GNN training
PRICE_SETTLEMENT_POINTS=HB_HOUSTON,HB_NORTH,HB_SOUTH,HB_WEST,HB_BUSAVG

# Dashboard → model API (override in dashboard service if needed)
MODEL_SERVER_URL=http://model-server:8000

# Training hyperparams (optional)
TRAINING_DAYS=90
LOAD_EPOCHS=80
PRICE_EPOCHS=80
AE_EPOCHS=60
XGB_ESTIMATORS=400
EARLY_STOP_PATIENCE=14
GNN_HIDDEN_DIM=96
GNN_DROPOUT=0.25
WEIGHT_DECAY=1e-4
LOAD_LR=8e-4
PRICE_LR=8e-4
AE_LR=1e-3
AE_WEIGHT_DECAY=1e-5
LOAD_LOSS=huber
LOAD_HUBER_DELTA=1.0
PRICE_HUBER_DELTA=2.0
XGB_EARLY_ROUNDS=40

# Dashboard
DASHBOARD_REFRESH_SECS=60

# Model API: CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Anomaly API percentile (match training defaults in gnn_anomaly.py)
ANOMALY_THRESHOLD_PERCENTILE=98
